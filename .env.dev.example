# =============================================================================
# Shepherd — NATIVE DEV environment template
# =============================================================================
# For local development with `./run-dev.sh` (everything runs natively on the host;
# only Postgres runs in Docker). Copy this file, then generate the few secrets:
#
#     cp .env.dev.example .env.dev.local
#
# Generate the throwaway dev secrets and paste them below:
#     openssl rand -base64 32                      # FLOCK_MASTER_KEY
#     openssl rand -base64 32                      # FLOCK_AGENTD_SECRET
#     node -e 'console.log(require("web-push").generateVAPIDKeys())'   # VAPID keys
#
# `.env.dev.local` is gitignored. These are DEV-ONLY throwaway values — never reuse
# them in production (use .env.example + Docker secrets for that).
# =============================================================================

# --- Database (Postgres runs in Docker, published on host :5432 by run-dev.sh) ---
DATABASE_URL=postgres://flock:flock@localhost:5432/flock

# --- Server ---
HOST=127.0.0.1
PORT=8080
PUBLIC_BASE_URL=http://localhost:5173
# Add the exact Tailnet URL/IP here when intentionally browsing through it.
# Never use wildcards; cookie mode does not bypass this WebSocket policy.
FLOCK_ALLOWED_ORIGINS=http://localhost:5173
# Plain-HTTP local dev: don't mark the session cookie Secure (the browser would drop it).
FLOCK_ALLOW_INSECURE_HTTP=1
FLOCK_PREVIEW_DOMAIN=preview.localhost
FLOCK_PREVIEW_BACKEND=hostname
FLOCK_PREVIEW_PORT_RANGE=
FLOCK_PREVIEW_FRAME_SOURCES=http://*.preview.localhost:11012
FLOCK_PREVIEW_HOST=0.0.0.0
FLOCK_PREVIEW_PORT=11012
FLOCK_PREVIEW_PUBLIC_PORT=11012
FLOCK_PREVIEW_MAX_CONNECTIONS=32
FLOCK_PREVIEW_MAX_REQUEST_BYTES=67108864
FLOCK_PREVIEW_MAX_RESPONSE_BYTES=67108864

# --- Secrets (DEV ONLY — regenerate; see the one-liners above) ---
FLOCK_MASTER_KEY=REPLACE_WITH_openssl_rand_base64_32
FLOCK_MASTER_KEY_VERSION=1

# --- Web Push (notifications on awaiting_input / done / error) ---
VAPID_PUBLIC_KEY=REPLACE_WITH_web-push_generateVAPIDKeys
VAPID_PRIVATE_KEY=REPLACE_WITH_web-push_generateVAPIDKeys
VAPID_SUBJECT=mailto:you@example.com

# --- flock-agentd (the node daemon) ---
# On: a node's terminals run through flock-agentd (local node via unix socket,
# SSH nodes bootstrapped over SSH). run-dev.sh builds + supervises the local daemon.
FLOCK_USE_AGENTD=1
# Absolute path to the built daemon dist dir (cd agentd && make dist).
FLOCK_AGENTD_DIST_DIR=/absolute/path/to/flock/agentd/dist
# Shared secret atop SSH (defense-in-depth). Must match what the daemon is started with.
FLOCK_AGENTD_SECRET=REPLACE_WITH_openssl_rand_base64_32
# Expected daemon version. LEAVE BLANK — the orchestrator reads it from the
# single source `agentd/VERSION`. Only set this to pin an explicit override; a
# stale value forces the daemon to re-ship/relaunch on every connect (kills sessions).
FLOCK_AGENTD_VERSION=
