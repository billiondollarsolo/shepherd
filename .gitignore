# Secrets — SSH keys, agentd secret, node credentials (NEVER commit).
# Root-only (`/secrets/`); do not use a bare `secrets/` pattern — that also
# ignored apps/orchestrator/src/secrets/ source modules and broke CI builds.
/secrets/
/backups/
*.pem
*_key
*.key
!*.pub
.claude/

# Vagrant machine state (contains generated private keys)
vagrant/.vagrant/

# Vendored external reference repos (their own git history, ~730MB) — not part of
# the Shepherd codebase. Re-clone separately if needed; do not embed.
/codex/
/orca/

# Reference: synara (external repo, for comparison — do not commit)
/synara/
