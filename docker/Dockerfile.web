# =============================================================================
# Shepherd web (React + Vite PWA) — production image (US-38)
# Multi-stage: build the static bundle, then serve it with nginx.
# No secrets baked in (NFR-DEP2): runtime config is fetched from the
# orchestrator API, not compiled into the bundle.
# Build context is the repo root.
#   docker build -f docker/Dockerfile.web -t shepherd-web .
# =============================================================================

# ---- Stage 1: base toolchain (Node 22 + pnpm via corepack) ------------------
FROM node:26-bookworm-slim@sha256:2d49d876e96237d76de412761cf05dbfe5aee325cc4406a4d41d5824c5bb8beb AS base
ENV PNPM_HOME=/pnpm
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable
WORKDIR /app

# ---- Stage 2: install workspace deps (cached on lockfile) -------------------
FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY packages/shared/package.json packages/shared/package.json
COPY apps/web/package.json apps/web/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile --store-dir /pnpm/store \
    --filter "@flock/web..."

# ---- Stage 3: build shared, then the web bundle -----------------------------
FROM deps AS build
COPY . .
RUN pnpm --filter "@flock/shared" run build \
    && pnpm --filter "@flock/web" run build

# ---- Stage 4: static serve via nginx ----------------------------------------
FROM nginx:1.31-alpine@sha256:7068961d45b07b2af510ac002e9daa63a1d3eba2111202d6768798690800fffd AS runtime

LABEL org.opencontainers.image.source="https://github.com/billiondollarsolo/shepherd" \
      org.opencontainers.image.licenses="MIT"

# Pull patched Alpine packages even when the pinned upstream manifest predates
# a security repository update; the release Trivy gate verifies the result.
ARG RELEASE_REFRESH=manual
# The upstream nginx image installs optional nginx.org dynamic modules that pin
# nginx to their exact package revision. Shepherd does not load those modules;
# remove them so Alpine can install its current security-patched nginx build.
RUN echo "$RELEASE_REFRESH" >/dev/null \
    && apk del \
        nginx-module-acme \
        nginx-module-geoip \
        nginx-module-image-filter \
        nginx-module-njs \
        nginx-module-xslt \
    && sed -i -E 's/^nginx=.*/nginx/' /etc/apk/world \
    && apk update \
    && apk upgrade --no-cache \
    && rm -rf /var/cache/apk/* \
    && rm -f /etc/nginx/conf.d/default.conf \
    && sed -i '1i pid /var/run/nginx.pid;' /etc/nginx/nginx.conf

# Keep Shepherd and bundled-font notices inside the distributed image.
COPY LICENSE THIRD_PARTY_NOTICES.md /usr/share/licenses/flock/
COPY apps/web/src/styles/fonts/OFL.txt /usr/share/licenses/flock/OFL-1.1.txt

# SPA + service-worker friendly nginx config is also reused by the local stack.
COPY docker/nginx-spa.conf /etc/nginx/http.d/default.conf

# Vite's default outDir is `dist`. Copy the built static bundle.
COPY --from=build /app/apps/web/dist /usr/share/html

EXPOSE 80
# nginx runs in the foreground in containers.
CMD ["nginx", "-g", "daemon off;"]
