# =============================================================================
# Flock orchestrator — production image (US-38, NFR-DEP1/DEP2)
# Multi-stage: deps -> build -> runtime. No secrets baked in (NFR-DEP2);
# everything sensitive is supplied at runtime via env / Docker secrets.
# Build context is the repo root.
#   docker build -f docker/Dockerfile.orchestrator -t flock-orchestrator .
# =============================================================================

# ---- Stage 0: build flock-agentd (T10) --------------------------------------
# The orchestrator uses flock-agentd as the ONLY transport for the LOCAL node, so
# the single-box deploy must ship + run the daemon in this image. Built here from
# source for every supported remote-node architecture and stamped from the
# single VERSION file (T14). The current image's architecture is also copied to
# /usr/local/bin for the bundled local node.
FROM golang:1.26-bookworm AS agentd-build
WORKDIR /agentd
COPY agentd/ ./
ARG TARGETARCH
RUN mkdir -p /out/dist \
    && for arch in amd64 arm64; do \
         CGO_ENABLED=0 GOOS=linux GOARCH=$arch \
           go build -ldflags "-s -w -X main.Version=$(cat VERSION)" \
           -o "/out/dist/flock-agentd-linux-$arch" . ; \
       done \
    && cp "/out/dist/flock-agentd-linux-${TARGETARCH:-amd64}" /out/flock-agentd

# ---- Stage 1: base toolchain (Node 22 + pnpm via corepack) ------------------
# T16: node base pinned to a digest for reproducible builds (the tag floats).
FROM node:26-bookworm-slim@sha256:e999d087492c7227c85adc70574cf9d3cce774c3e6d7b8dfe473ee6b142c8f2c AS base
ENV PNPM_HOME=/pnpm
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable
# Native production dependencies (node-pty/ssh2) compile in the dependency
# stages. The final runtime image remains lean because it does not inherit base.
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 make g++ \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app

# ---- Stage 2: install ALL workspace deps (cached on lockfile) ---------------
FROM base AS deps
# Copy only manifests first so the dependency layer is cached across code edits.
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY packages/shared/package.json packages/shared/package.json
COPY apps/orchestrator/package.json apps/orchestrator/package.json
COPY apps/web/package.json apps/web/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile --store-dir /pnpm/store

# ---- Stage 3: build shared + orchestrator -----------------------------------
FROM deps AS build
COPY . .
# Build the shared contracts package first, then the orchestrator.
RUN pnpm --filter "@flock/shared" run build \
    && pnpm --filter "@flock/orchestrator" run build

# ---- Stage 4: production deps only (prune dev) ------------------------------
FROM base AS prod-deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY packages/shared/package.json packages/shared/package.json
COPY apps/orchestrator/package.json apps/orchestrator/package.json
COPY apps/web/package.json apps/web/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile --prod --store-dir /pnpm/store \
    --filter "@flock/orchestrator..." --filter "@flock/shared"

# ---- Stage 5: lean runtime --------------------------------------------------
# T16: pinned to a digest for reproducible builds (the tag floats).
FROM node:26-bookworm-slim@sha256:e999d087492c7227c85adc70574cf9d3cce774c3e6d7b8dfe473ee6b142c8f2c AS runtime
LABEL org.opencontainers.image.source="https://github.com/billiondollarsolo/flock" \
      org.opencontainers.image.licenses="MIT"
ENV NODE_ENV=production
ENV PNPM_HOME=/pnpm
ENV PATH="$PNPM_HOME:$PATH"
# UTF-8 locale so the LOCAL node's tmux (running inside this container) renders
# agent TUIs correctly. Without it, the container's POSIX locale makes tmux mangle
# box-drawing / block / icon glyphs (Flock also forces it per command, but this is
# belt-and-suspenders + helps any interactive use). C.UTF-8 ships with glibc.
ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    LC_CTYPE=C.UTF-8
RUN corepack enable

# Runtime OS deps:
#  - tmux: process persistence for sessions on the local node (PRD §6.1)
#  - openssh-client: SshTransport + reverse tunnels (PRD §6.2)
#  - git: read-only diff pane (US-33)
#  - ca-certificates: outbound TLS (Web Push, etc.)
#  - curl: fetch the agent CLI installers below
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        tmux \
        openssh-client \
        git \
        ca-certificates \
        curl \
        gosu \
    && rm -rf /var/lib/apt/lists/*

# Separate OS identities: the orchestrator is the trusted control client while
# all coding agents run as flock-agent. Only flock-control joins the runtime
# group (read-only operational access to workspaces); flock-agent never joins a
# control or Docker-socket group.
RUN groupadd --system flock-control \
    && useradd --system --create-home --home-dir /home/flock-control --gid flock-control --shell /bin/bash flock-control \
    && groupadd --system flock-agent \
    && useradd --system --create-home --home-dir /home/flock-agent --gid flock-agent --shell /bin/bash flock-agent \
    && usermod -aG flock-agent flock-control

# Agent CLIs on PATH so a session on the LOCAL node (i.e. this container, when
# Flock is deployed in Docker) can launch a real agent — same set the SSH node
# image installs. Release builds intentionally install the newest available
# versions; a failed install fails the image instead of silently publishing an
# incomplete runtime. Real multi-node deploys still run agents on SSH nodes;
# this makes the single-box deploy work too.
RUN npm install -g @openai/codex@latest
RUN curl -fsSL https://opencode.ai/install \
      | bash -s -- --no-modify-path \
    && cp /root/.opencode/bin/opencode /usr/local/bin/opencode

WORKDIR /app

# Bring over pruned production node_modules (root + workspace symlinks).
COPY --from=prod-deps /app/node_modules ./node_modules
COPY --from=prod-deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=prod-deps /app/apps/orchestrator/node_modules ./apps/orchestrator/node_modules

# Manifests (needed for workspace resolution + `pnpm` runtime scripts).
COPY pnpm-workspace.yaml package.json ./
COPY packages/shared/package.json ./packages/shared/package.json
COPY apps/orchestrator/package.json ./apps/orchestrator/package.json

# Built artifacts + Drizzle migrations.
COPY --from=build /app/packages/shared/dist ./packages/shared/dist
COPY --from=build /app/apps/orchestrator/dist ./apps/orchestrator/dist
COPY apps/orchestrator/drizzle ./apps/orchestrator/drizzle
COPY apps/orchestrator/drizzle.config.ts ./apps/orchestrator/drizzle.config.ts
COPY LICENSE THIRD_PARTY_NOTICES.md /usr/share/doc/flock/

# T10: ship flock-agentd (the local-node PTY transport) + the entrypoint that
# supervises it alongside the orchestrator. agentd/VERSION ships too so
# `flock-agentd version` agrees with the orchestrator (T14).
COPY --from=agentd-build /out/flock-agentd /usr/local/bin/flock-agentd
COPY --from=agentd-build /out/dist /app/agentd/dist
COPY agentd/VERSION /app/agentd/VERSION
COPY docker/orchestrator-entrypoint.sh /usr/local/bin/flock-entrypoint.sh
RUN chmod +x /usr/local/bin/flock-agentd /usr/local/bin/flock-entrypoint.sh

# The unix socket the daemon listens on and the orchestrator dials (must match;
# the orchestrator reads FLOCK_AGENTD_SOCKET). /tmp is writable by the node user.
ENV FLOCK_AGENTD_SOCKET=/run/flock-agentd/control.sock

# Default internal port (overridable via env). TLS is terminated upstream.
ENV PORT=8080
EXPOSE 8080

# A node-owned workspace for LOCAL-node session working dirs. A named volume
# mounted here (see docker-compose.yml) initialises with this dir's ownership, so
# the non-root `node` user can write — and local sessions survive restarts.
RUN mkdir -p /home/flock-agent/workspace /var/lib/flock-agentd /run/flock-agentd \
    && chown -R flock-agent:flock-agent /home/flock-agent \
    && chown root:flock-control /var/lib/flock-agentd /run/flock-agentd \
    && chmod 0750 /var/lib/flock-agentd /run/flock-agentd

# PID 1 starts as root solely to supervise the root agentd service and establish
# socket/file ownership, then execs the orchestrator as flock-control. Agent
# processes are always dropped again to flock-agent by agentd.
USER root

# Entrypoint (T10): supervises flock-agentd, runs idempotent migrations, then
# installs the latest Claude Code for the local node (without redistributing its
# commercially licensed binary in Flock's image), then execs the orchestrator.
# `pnpm` workspace scripts stay the source of truth for migrate/start.
CMD ["/usr/local/bin/flock-entrypoint.sh"]
