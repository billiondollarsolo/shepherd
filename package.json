{
  "name": "flock",
  "version": "0.0.0",
  "private": true,
  "description": "Flock \u2014 a web cockpit for supervising CLI coding agents (Claude Code, Codex, OpenCode) over SSH.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "pnpm": {
    "overrides": {
      "tar-fs@>=2.0.0 <2.1.4": ">=2.1.4",
      "tar-fs@>=3.0.0 <3.1.1": ">=3.1.1",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "form-data": ">=4.0.6"
    }
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "pnpm -r test:unit",
    "test:int": "pnpm -r test:int",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "db:up": "docker start flock-dev-postgres-1 2>/dev/null || docker compose -f docker-compose.dev.yml up -d postgres",
    "dev:migrate": "tsx --env-file=.env.dev.local apps/orchestrator/src/db/migrate.ts",
    "dev:api": "pnpm db:up && pnpm dev:migrate && tsx watch --env-file=.env.dev.local apps/orchestrator/src/index.ts",
    "dev:web": "pnpm --filter @flock/web dev",
    "dev:native": "pnpm db:up && pnpm dev:migrate && concurrently -n api,web -c blue,magenta \"tsx watch --env-file=.env.dev.local apps/orchestrator/src/index.ts\" \"pnpm --filter @flock/web dev\""
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "22.10.2",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "concurrently": "^10.0.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "3.4.2",
    "tsx": "4.23.0",
    "typescript": "5.7.2",
    "vite": "6.4.3",
    "vitest": "3.2.6"
  }
}
