# =============================================================================
# Flock — production environment template (US-38, NFR-DEP2)
# =============================================================================
# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# `docker compose` automatically reads `.env` in the project root. NOTHING here
# is baked into an image — secrets are supplied at runtime via env / secret
# files only (NFR-DEP2). `.env` is gitignored; never commit real secrets.
#
# For higher-assurance deployments, prefer the Docker secret files in
# `./secrets/*` (see FLOCK_MASTER_KEY_FILE / POSTGRES_PASSWORD_FILE below and
# the `secrets:` block in docker-compose.yml) over plain env vars.
# =============================================================================

# Release images. Pin this value during upgrades; do not deploy `latest` in
# production. Override the registry when publishing a fork.
FLOCK_VERSION=0.3.0
FLOCK_IMAGE_REGISTRY=ghcr.io/billiondollarsolo

# -----------------------------------------------------------------------------
# Postgres (durable system of record — NOT on the live status path, PRD §6.6)
# -----------------------------------------------------------------------------
POSTGRES_USER=flock
POSTGRES_DB=flock
# Internal compose port is fixed at 5432; this only maps it on the host loopback
# for debugging. Leave blank / comment the ports mapping in prod.
POSTGRES_HOST_PORT=5432

# Optional full connection-string override. Leave blank to construct it from
# POSTGRES_USER/POSTGRES_DB and `secrets/postgres_password` automatically.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Orchestrator
# -----------------------------------------------------------------------------
NODE_ENV=production

# Internal listen port for the orchestrator HTTP/WS server. NOT published to the
# host (US-39): the orchestrator is reachable only via the Caddy TLS proxy on
# the internal compose network (NFR-SEC1).
PORT=8080

# Public base URL used to build hook callback URLs injected into agent sessions
# and for Web Push / cookie domain. Use the HTTPS Caddy URL in production,
# e.g. https://flock.example.com
PUBLIC_BASE_URL=https://localhost

# -----------------------------------------------------------------------------
# TLS reverse proxy (Caddy, US-39 / NFR-SEC1)
# -----------------------------------------------------------------------------
# Caddy terminates TLS in front of everything and is the ONLY published service.
# With a real domain Caddy auto-provisions a Let's Encrypt cert; for
# `localhost`/IP-only deploys it mints a locally-trusted internal cert.
FLOCK_DOMAIN=localhost
ACME_EMAIL=
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443

# -----------------------------------------------------------------------------
# Secret store master key (encryption at rest — PRD §6, US-3, NFR-SEC2)
# -----------------------------------------------------------------------------
# 32-byte key, base64-encoded. Generate with:
#     openssl rand -base64 32
# Provide EITHER FLOCK_MASTER_KEY (env) OR FLOCK_MASTER_KEY_FILE (secret file).
# The secret-file form is preferred in production (NFR-DEP2).
FLOCK_MASTER_KEY=
FLOCK_MASTER_KEY_FILE=/run/secrets/flock_master_key

# Key version for rotation (PRD §6 — key_version enables decrypt of old data).
FLOCK_MASTER_KEY_VERSION=1

# Install the latest Claude Code from Anthropic when a new orchestrator container
# starts. Set to 0 only when a custom image/volume supplies a user-managed version.
FLOCK_INSTALL_CLAUDE_CODE=1

# -----------------------------------------------------------------------------
# Web session cookies / auth (US-5, NFR-SEC6)
# -----------------------------------------------------------------------------
# Cookies are issued with `Secure` by default (production behind TLS). ONLY for
# local plain-HTTP dev (no TLS) set FLOCK_INSECURE_COOKIES=1 to drop `Secure` so
# the browser will store the cookie. Leave unset in production.
#   FLOCK_INSECURE_COOKIES=1
# (There is no SESSION_SECRET / COOKIE_SECURE knob — the cookie carries only an
# opaque random session id validated against the DB; cookie security is governed
# solely by the var above.)

# -----------------------------------------------------------------------------
# Web Push / VAPID (US-22, FR-ST4)
# -----------------------------------------------------------------------------
# Generate a keypair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# -----------------------------------------------------------------------------
# Per-session browser containers (Layer A — PRD §6.5, US-25, NFR-DEP1/SEC5)
# -----------------------------------------------------------------------------
# Image used for each dynamically-launched, isolated per-session Chrome
# container. Managed at runtime by the orchestrator via dockerode against the
# mounted Docker socket — NOT declared as a compose service.
BROWSER_IMAGE=ghcr.io/billiondollarsolo/flock-session-chrome:0.3.0

# Hard cap on concurrent per-session browser containers (NFR-PERF3 / US-29).
BROWSER_MAX_CONCURRENT=4

# Docker socket path the orchestrator uses to launch browser containers.
# Mounted read-write into the orchestrator container in docker-compose.yml.
DOCKER_SOCKET=/var/run/docker.sock

# Docker network the orchestrator attaches per-session browser containers to so
# it can reach their loopback-bound CDP endpoint (set to the compose network).
BROWSER_NETWORK=flock_internal
