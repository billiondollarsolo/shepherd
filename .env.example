# =============================================================================
# Shepherd — production environment template (US-38, NFR-DEP2)
# =============================================================================
# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# `docker compose` automatically reads `.env` in the project root. NOTHING here
# is baked into an image — secrets are supplied at runtime via env / secret
# files only (NFR-DEP2). `.env` is gitignored; never commit real secrets.
#
# For higher-assurance deployments, prefer the Docker secret files in
# `./secrets/*` (see FLOCK_MASTER_KEY_FILE / POSTGRES_PASSWORD_FILE below and
# the `secrets:` block in docker-compose.yml) over plain env vars.
# =============================================================================

# Release images. Pin this value during upgrades; do not deploy `latest` in
# production. Override the registry when publishing a fork.
FLOCK_VERSION=0.6.1
# Local node runtime is pinned independently so compatible active agents survive
# routine control-plane upgrades. The upgrade helper changes this only when idle.
FLOCK_NODE_RUNTIME_VERSION=0.6.1
FLOCK_IMAGE_REGISTRY=ghcr.io/billiondollarsolo

# -----------------------------------------------------------------------------
# PostgreSQL (durable system of record — NOT on the live status path, PRD §6.6)
# -----------------------------------------------------------------------------
# Official upstream PostgreSQL 16, pinned to the latest reviewed patch manifest.
# Update the digest deliberately; never change this to a floating `latest` tag.
POSTGRES_IMAGE=postgres:16-bookworm@sha256:92620daddcd947f8d5ab5ba66e848702fe443d87fed30c4cea8e389fd78dfc55
POSTGRES_USER=flock
POSTGRES_DB=flock
# PostgreSQL remains on the internal Compose network and has no host port.

# Optional full connection-string override. Leave blank to construct it from
# POSTGRES_USER/POSTGRES_DB and `secrets/postgres_password` automatically.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Orchestrator
# -----------------------------------------------------------------------------
NODE_ENV=production

# Internal listen port for the orchestrator HTTP/WS server. NOT published to the
# host (US-39): the orchestrator is reachable only via the Traefik TLS proxy on
# the internal compose network (NFR-SEC1).
PORT=8080

# Public base URL used to build hook callback URLs injected into agent sessions
# and for Web Push / cookie domain. Use the HTTPS Traefik URL in production,
# e.g. https://shepherd.example.com
PUBLIC_BASE_URL=https://shepherd.example.com

# Exact origins allowed to open authenticated browser WebSockets. Production
# startup fails if this is missing or does not include PUBLIC_BASE_URL. Use a
# comma-separated list with no paths or wildcards when multiple browser URLs are
# intentional, e.g. https://shepherd.example.com,https://shepherd.tailnet.ts.net
FLOCK_ALLOWED_ORIGINS=https://shepherd.example.com
# Dedicated suffix for isolated, untrusted dev-server previews. For a real
# deployment, create wildcard DNS for `*.preview.example.com` and set this.
# Localhost uses `preview.localhost` automatically when this is empty.
FLOCK_PREVIEW_DOMAIN=
# The base HTTP-01 profile keeps Preview disabled. The DNS-01 and external-proxy
# profiles select `hostname`; private HTTP selects `port-pool` unless overridden.
FLOCK_PREVIEW_BACKEND=disabled
FLOCK_PREVIEW_PORT_RANGE=

# Optional Docker network names. The defaults preserve the standard single-stack
# deployment; set unique values when running more than one Shepherd installation
# on the same host.
FLOCK_EDGE_NETWORK_NAME=shepherd_edge
FLOCK_DATA_NETWORK_NAME=shepherd_data
FLOCK_RUNTIME_NETWORK_NAME=shepherd_runtime
# Exact, space-separated Preview origins allowed by the main-page CSP. Settings
# generates this value for private port-pool and external-proxy deployments.
FLOCK_PREVIEW_FRAME_SOURCES=
FLOCK_PREVIEW_TTL_MS=28800000
FLOCK_PREVIEW_MAX_CONCURRENT=16
FLOCK_PREVIEW_MAX_CONNECTIONS=32
FLOCK_PREVIEW_CONNECT_TIMEOUT_MS=3000
FLOCK_PREVIEW_UPSTREAM_TIMEOUT_MS=120000
FLOCK_PREVIEW_MAX_REQUEST_BYTES=67108864
FLOCK_PREVIEW_MAX_RESPONSE_BYTES=67108864

# -----------------------------------------------------------------------------
# TLS reverse proxy (official Traefik, US-39 / NFR-SEC1)
# -----------------------------------------------------------------------------
# Traefik terminates TLS and is the ONLY published service. The base profile uses
# HTTP-01 for the control plane; a DNS profile is required for wildcard Preview.
TRAEFIK_IMAGE=traefik:v3.7@sha256:1cb3845d7a05e1473c9086351426597e911db49db382b6e4769f9b0744962ac8
FLOCK_DOMAIN=shepherd.example.com
ACME_EMAIL=admin@example.com
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443

# Optional DNS-01 overrides are useful when inbound ports 80/443 are unavailable
# or wildcard certificate validation is required. The credentials create only
# temporary ACME TXT records; DNS A/AAAA/wildcard routing remains operator-owned.
# Select exactly one checked-in override when starting Compose:
#   docker-compose.dns-cloudflare.yml  OR  docker-compose.dns-route53.yml
# These are host paths to secret files, not credential values.
CLOUDFLARE_API_TOKEN_FILE=./secrets/cloudflare_api_token
# Standard AWS shared-credentials format; individual AWS_*_FILE variables are
# not supported by lego's AWS SDK integration.
ROUTE53_SHARED_CREDENTIALS_FILE=./secrets/route53_credentials
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Secret store master key (encryption at rest — PRD §6, US-3, NFR-SEC2)
# -----------------------------------------------------------------------------
# 32-byte key, base64-encoded. Generate with:
#     openssl rand -base64 32
# Provide EITHER FLOCK_MASTER_KEY (env) OR FLOCK_MASTER_KEY_FILE (secret file).
# The secret-file form is preferred in production (NFR-DEP2).
FLOCK_MASTER_KEY=
FLOCK_MASTER_KEY_FILE=/run/secrets/flock_master_key

# Key version for rotation (PRD §6 — key_version enables decrypt of old data).
FLOCK_MASTER_KEY_VERSION=1

# Install the latest Claude Code from Anthropic when a new node-runtime container
# starts. Set to 0 only when a custom image/volume supplies a user-managed version.
FLOCK_INSTALL_CLAUDE_CODE=1

# -----------------------------------------------------------------------------
# Web session cookies / auth (US-5, NFR-SEC6)
# -----------------------------------------------------------------------------
# Production Compose mounts `secrets/setup_token` at this path. The token is an
# out-of-band capability required only for the first administrator creation;
# generate it with `openssl rand -base64 48` and keep the file mode at 0600.
FLOCK_SETUP_TOKEN_FILE=/run/secrets/setup_token

# Cookies are `Secure` in both TLS modes. The private-HTTP override requires the
# following acknowledgement to equal `1`; leave it blank for every HTTPS deploy.
FLOCK_ALLOW_INSECURE_HTTP=
# There is no SESSION_SECRET / COOKIE_SECURE knob: the cookie carries an opaque
# random id validated against the DB. This acknowledgement never relaxes the
# exact WebSocket origin allowlist.

# -----------------------------------------------------------------------------
# Web Push / VAPID (US-22, FR-ST4)
# -----------------------------------------------------------------------------
# Generate a keypair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Host directory mounted at /backups for encrypted .flockvault archives.
FLOCK_BACKUP_DIR=./backups
