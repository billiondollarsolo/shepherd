{
  "name": "@flock/web",
  "version": "0.6.2",
  "private": true,
  "type": "module",
  "description": "Shepherd web paddock: nodes, projects, multi-agent Pens, live terminals, diffs, and mobile access.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/billiondollarsolo/shepherd.git",
    "directory": "apps/web"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:int": "echo 'no integration tests in @flock/web (see test:e2e)' && exit 0",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist *.tsbuildinfo"
