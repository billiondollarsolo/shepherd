{
  "name": "@flock/orchestrator",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "description": "Shepherd orchestrator: SSH/agentd orchestration, live status fan-out, event history, and secure remote development access.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/billiondollarsolo/shepherd.git",
    "directory": "apps/orchestrator"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "migrate": "node dist/db/migrate.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "account:reset-password": "tsx src/db/reset-password.ts",
    "vault": "node dist/operations/vault-cli.js",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run --config vitest.int.config.ts --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@flock/shared": "workspace:*",
    "argon2": "0.41.1",
    "cookie": "1.0.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "pg": "8.13.1",
    "ssh2": "1.16.0",
    "web-push": "3.6.7",
    "ws": "8.21.0",
    "yaml": "^2.9.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "@types/ssh2": "1.15.1",
    "@types/web-push": "3.6.4",
    "@types/ws": "8.5.13",
    "drizzle-kit": "0.30.1",
    "tsx": "4.23.0",
    "typescript": "5.7.2",
    "vitest": "3.2.6"
  }
}
