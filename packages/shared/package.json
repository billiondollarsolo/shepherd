{
  "name": "@flock/shared",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Shared domain types, StatusEnum, and REST/WS contracts (zod) for Shepherd. Imported by both orchestrator and web. Never duplicate a type.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/billiondollarsolo/shepherd.git",
    "directory": "packages/shared"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --force",
    "typecheck": "tsc -b",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:int": "echo 'no integration tests in @flock/shared' && exit 0",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "3.24.1"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "vitest": "3.2.6"
  }
}
