# Deterministic isolated node_modules layout (symlinked virtual store).
node-linker=isolated
# Do not hoist everything to the root; keeps dependency boundaries honest.
shamefully-hoist=false
# Allow internal @flock/* packages to link via the workspace: protocol.
link-workspace-packages=true
# Peer dep mismatches warn rather than hard-fail (skeleton stability).
strict-peer-dependencies=false
# Do NOT set store-dir here. An absolute path like /pnpm-store is fine in Docker
# (see docker-compose.dev.yml) but breaks GitHub Actions and bare-metal installs
# (EACCES mkdir '/pnpm-store'). Docker compose sets npm_config_store_dir; production
# Dockerfiles pass --store-dir /pnpm/store to the BuildKit cache mount.
