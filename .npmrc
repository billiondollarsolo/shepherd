# Deterministic isolated node_modules layout (symlinked virtual store).
node-linker=isolated
# Do not hoist everything to the root; keeps dependency boundaries honest.
shamefully-hoist=false
# Allow internal @flock/* packages to link via the workspace: protocol.
link-workspace-packages=true
# Peer dep mismatches warn rather than hard-fail (skeleton stability).
strict-peer-dependencies=false
# Store lives on a named docker volume mounted at /pnpm-store (see docker-compose.dev.yml).
store-dir=/pnpm-store
